<?xml version="1.0"?>
<!-- LEKIWI Full Robot: base + gimbal + sensors -->
<robot name="lekiwi_fcr" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="enable_depth_camera" default="false"/>

  <!-- Include sub-models -->
  <xacro:include filename="lekiwi_base.xacro"/>
  <xacro:include filename="lekiwi_gimbal.xacro"/>
  <xacro:include filename="lekiwi_sensors.xacro"/>

  <!-- Instantiate base chassis -->
  <xacro:lekiwi_base prefix=""/>

  <!-- Instantiate gimbal on top of base -->
  <xacro:lekiwi_gimbal parent="base_link" prefix=""/>

  <!-- Instantiate sensors -->
  <xacro:lekiwi_sensors parent="base_link" prefix="" enable_depth_camera="$(arg enable_depth_camera)"/>

  <!-- Gazebo plugin: joint state publisher (TF + RViz updates for all joints) -->
  <gazebo>
    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <remapping>joint_states:=/joint_states</remapping>
      </ros>
      <joint_name>front_wheel_joint</joint_name>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
      <joint_name>gimbal_yaw_joint</joint_name>
      <joint_name>gimbal_pitch_joint</joint_name>
      <update_rate>100</update_rate>
    </plugin>
  </gazebo>

  <!-- Gazebo plugin: drives gimbal yaw/pitch joints from /cmd_gimbal -->
  <gazebo>
    <plugin name="gimbal_controller" filename="libgimbal_controller_plugin.so">
      <yaw_joint>gimbal_yaw_joint</yaw_joint>
      <pitch_joint>gimbal_pitch_joint</pitch_joint>
    </plugin>
  </gazebo>

  <!-- Gazebo plugin for omnidirectional drive -->
  <gazebo>
    <plugin name="omni_drive" filename="libgazebo_ros_planar_move.so">
      <ros>
        <remapping>cmd_vel:=/cmd_vel</remapping>
        <remapping>odom:=/odom</remapping>
      </ros>
      <odom_frame_id>odom</odom_frame_id>
      <robot_base_frame_id>base_link</robot_base_frame_id>
      <linear_velocity_max>1.0</linear_velocity_max>
      <angular_velocity_max>2.0</angular_velocity_max>
    </plugin>
  </gazebo>

</robot>
