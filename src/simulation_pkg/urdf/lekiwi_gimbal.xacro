<?xml version="1.0"?>
<!-- LEKIWI Pan-Tilt Gimbal: 2-axis (yaw + pitch) with camera mount -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="lekiwi_gimbal" params="parent:=base_link prefix:=''">
    <!-- Pan (yaw) link -->
    <link name="${prefix}gimbal_yaw_link">
      <visual name="yaw_base">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.085" length="0.07"/>
        </geometry>
        <material name="gimbal_yaw_cyan">
          <color rgba="0.0 0.9 0.9 1.0"/>
        </material>
      </visual>
      <visual name="yaw_upright">
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.13 0.12"/>
        </geometry>
        <material name="gimbal_side_cyan">
          <color rgba="0.0 0.9 0.9 1.0"/>
        </material>
      </visual>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="5e-4" iyy="5e-4" izz="1e-3" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    <gazebo reference="${prefix}gimbal_yaw_link">
      <material>Gazebo/Cyan</material>
    </gazebo>

    <joint name="${prefix}gimbal_yaw_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="${prefix}gimbal_yaw_link"/>
      <origin xyz="0 0 0.13" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit effort="10" velocity="6.28" lower="-3.14" upper="3.14"/>
    </joint>

    <!-- Tilt (pitch) link -->
    <link name="${prefix}gimbal_pitch_link">
      <visual name="pitch_bar">
        <origin xyz="0.035 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.16 0.055 0.05"/>
        </geometry>
        <material name="gimbal_pitch_magenta">
          <color rgba="0.95 0.1 0.7 1.0"/>
        </material>
      </visual>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="2e-4" iyy="2e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    <gazebo reference="${prefix}gimbal_pitch_link">
      <material>Gazebo/Magenta</material>
    </gazebo>

    <joint name="${prefix}gimbal_pitch_joint" type="revolute">
      <parent link="${prefix}gimbal_yaw_link"/>
      <child link="${prefix}gimbal_pitch_link"/>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="5" velocity="3.14" lower="-1.57" upper="1.57"/>
    </joint>

    <!-- Camera link (mounted on pitch axis) -->
    <link name="${prefix}camera_link">
      <visual name="camera_body">
        <origin xyz="0.045 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.11 0.055 0.045"/>
        </geometry>
        <material name="camera_blue">
          <color rgba="0.05 0.12 0.75 1.0"/>
        </material>
      </visual>
      <visual name="camera_lens">
        <origin xyz="0.11 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="0.018" length="0.018"/>
        </geometry>
        <material name="lens_black">
          <color rgba="0.02 0.02 0.02 1.0"/>
        </material>
      </visual>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="1e-5" iyy="1e-5" izz="1e-5" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    <gazebo reference="${prefix}camera_link">
      <material>Gazebo/Blue</material>
    </gazebo>

    <joint name="${prefix}camera_joint" type="fixed">
      <parent link="${prefix}gimbal_pitch_link"/>
      <child link="${prefix}camera_link"/>
      <origin xyz="0.11 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Camera optical frame (ROS convention: z-forward, x-right, y-down) -->
    <link name="${prefix}camera_optical_link"/>
    <joint name="${prefix}camera_optical_joint" type="fixed">
      <parent link="${prefix}camera_link"/>
      <child link="${prefix}camera_optical_link"/>
      <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    </joint>

  </xacro:macro>
</robot>
